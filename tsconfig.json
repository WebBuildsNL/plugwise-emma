{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["homey"]
  },
  "include": [
    "app.js",
    "drivers/**/*.js"
  ],
  "exclude": [
    "node_modules"
  ]
}
